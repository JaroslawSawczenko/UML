@startuml diagram-sekwencji
' Diagram sekwencji - dodawanie recenzji przez zalogowanego uzytkownika
skinparam dpi 110
skinparam shadowing false
autonumber

actor "Użytkownik" as U
participant "Frontend\n(React.js/Next.js)" as F
participant "API Endpoint\n(FastAPI)" as API
control "Auth Middleware\n(JWT)" as Auth
participant "SQLAlchemy\nORM" as ORM
database "Baza Danych\n(PostgreSQL/MySQL)" as DB

U -> F : Wpisuje treść recenzji i klika "Dodaj"
activate F
F -> API : POST /api/reviews\n(Header: Bearer JWT, Body: content, movie_id)
activate API
API -> Auth : weryfikuj_token(JWT)
activate Auth
Auth --> API : token_ok (user_id)
deactivate Auth
API -> ORM : create_review(user_id, movie_id, content)
activate ORM
ORM -> DB : INSERT INTO Reviews (...)
activate DB
DB --> ORM : success
deactivate DB
ORM --> API : review_object
deactivate ORM
API --> F : 201 Created (JSON)
deactivate API
F --> U : Wyświetla nową recenzję na liście
deactivate F
@enduml
