@startuml diagram-wdrozenia
' Diagram wdrozenia - architektura uruchomieniowa aplikacji Flicker
!pragma layout smetana
skinparam dpi 110
skinparam shadowing false

node "Urządzenie Użytkownika" <<Device>> {
  node "Przeglądarka Internetowa" <<Execution Environment>> {
    artifact "Aplikacja SPA\n(React.js / Next.js, Axios, TailwindCSS)" as SPA
  }
}

node "Serwer Aplikacyjny Backend" <<Server>> {
  node "Python Environment" <<Execution Environment>> {
    artifact "Flicker API\n(FastAPI, JWT)" as API
    artifact "ORM\n(SQLAlchemy)" as ORM
  }
}

node "Serwer Bazy Danych" <<Server>> {
  database "RDBMS (PostgreSQL / MySQL)" {
    artifact "Baza Danych Flicker\n(Tabele: Users, Movies, Ratings, Reviews)" as DBF
  }
}

SPA --> API : <<protokół>>\nHTTP/REST (JSON)
API ..> ORM : używa
ORM --> DBF : <<protokół>>\nTCP/IP (SQL)
@enduml
